<!DOCTYPE html>
<html lang="pt-BR">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>STI Inventory - Consulta de Clientes</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
    background:#f4f7fb;
    font-family:Arial, Helvetica, sans-serif;
}

.sidebar{
    background:#111827;
    min-height:100vh;
    color:white;
}

.sidebar-title{
    padding:25px;
    font-size:1.4rem;
    font-weight:bold;
    border-bottom:1px solid #1f2937;
}

.sidebar a{
    display:block;
    padding:15px 25px;
    text-decoration:none;
    color:#d1d5db;
}

.sidebar a:hover{
    background:#1f2937;
    color:white;
}

.topbar{
    background:white;
    border-radius:12px;
    padding:15px 25px;
    box-shadow:0 2px 10px rgba(0,0,0,.08);
}

.user-avatar{
    width:42px;
    height:42px;
    border-radius:50%;
    background:#0d6efd;
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    font-weight:bold;
}

.card-custom{
    border:none;
    border-radius:15px;
    box-shadow:0 2px 10px rgba(0,0,0,.08);
}

.client-card{
    border:none;
    border-radius:15px;
    transition:.3s;
    cursor:pointer;
    box-shadow:0 2px 10px rgba(0,0,0,.08);
}

.client-card:hover{
    transform:translateY(-5px);
}

.client-logo{
    width:55px;
    height:55px;
    border-radius:50%;
    background:#0d6efd;
    color:white;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:1.2rem;
    font-weight:bold;
}

</style>

</head>

<body>

<div class="container-fluid">

<div class="row">

<!-- MENU -->

<div class="col-md-2 sidebar p-0">

    <div class="sidebar-title">
        STI Inventory
    </div>

    <a href="#">🏠 Dashboard</a>
    <a href="#">👥 Clientes</a>
    <a href="#">📦 Serviços</a>
    <a href="#">☁ Recursos</a>
    <a href="#">📊 Relatórios</a>
    <a href="#">⚙ Configurações</a>

</div>

<!-- CONTEUDO -->

<div class="col-md-10 p-4">

    <!-- TOPO -->

    <div class="topbar d-flex justify-content-between align-items-center mb-4">

        <div>

            <h4 class="mb-0">
                Consulta de Clientes
            </h4>

            <small class="text-muted">
                Pesquise e visualize informações dos clientes
            </small>

        </div>

        <div class="d-flex align-items-center">

            <div class="text-end me-3">

                <div class="fw-bold">
                    andrenascimento
                </div>

                <small class="text-muted">
                    Administrador
                </small>

            </div>

            <div class="user-avatar">
                A
            </div>

        </div>

    </div>

    <!-- INDICADORES -->

    <div class="row mb-4">

        <div class="col-md-3">

            <div class="card card-custom">

                <div class="card-body">

                    <h6>Total de Clientes</h6>
                    <h2>147</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card card-custom">

                <div class="card-body">

                    <h6>Ativos</h6>
                    <h2>142</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card card-custom">

                <div class="card-body">

                    <h6>Suspensos</h6>
                    <h2>3</h2>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card card-custom">

                <div class="card-body">

                    <h6>Novos no Mês</h6>
                    <h2>8</h2>

                </div>

            </div>

        </div>

    </div>

    <!-- FILTROS -->

    <div class="card card-custom mb-4">

        <div class="card-body">

            <div class="row">

                <div class="col-md-6">

                    <input
                        type="text"
                        class="form-control form-control-lg"
                        placeholder="Pesquisar cliente...">

                </div>

                <div class="col-md-3">

                    <select class="form-select form-select-lg">

                        <option>Status</option>
                        <option>Ativo</option>
                        <option>Suspenso</option>

                    </select>

                </div>

                <div class="col-md-3">

                    <button class="btn btn-primary btn-lg w-100">
                        Pesquisar
                    </button>

                </div>

            </div>

        </div>

    </div>

    <!-- CLIENTES -->

    <div class="row">

        <div class="col-md-4 mb-4">

            <div class="card client-card">

                <div class="card-body">

                    <div class="d-flex align-items-center mb-3">

                        <div class="client-logo">
                            A
                        </div>

                        <div class="ms-3">

                            <h5 class="mb-0">
                                Alpha Tecnologia
                            </h5>

                            <small class="text-muted">
                                12.345.678/0001-00
                            </small>

                        </div>

                    </div>

                    <p class="text-muted">

                        Cliente AWS com ambientes de produção,
                        banco de dados PostgreSQL e backups.

                    </p>

                    <span class="badge bg-success">
                        Ativo
                    </span>

                    <hr>

                    <div class="d-flex justify-content-between">

                        <button class="btn btn-outline-primary">
                            Visualizar
                        </button>

                        <button class="btn btn-primary">
                            Editar
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card client-card">

                <div class="card-body">

                    <div class="d-flex align-items-center mb-3">

                        <div class="client-logo bg-success">
                            B
                        </div>

                        <div class="ms-3">

                            <h5 class="mb-0">
                                Beta Logística
                            </h5>

                            <small class="text-muted">
                                98.765.432/0001-99
                            </small>

                        </div>

                    </div>

                    <p class="text-muted">

                        Ambiente híbrido AWS e On-Premises
                        administrado pela STI.

                    </p>

                    <span class="badge bg-success">
                        Ativo
                    </span>

                    <hr>

                    <div class="d-flex justify-content-between">

                        <button class="btn btn-outline-primary">
                            Visualizar
                        </button>

                        <button class="btn btn-primary">
                            Editar
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card client-card">

                <div class="card-body">

                    <div class="d-flex align-items-center mb-3">

                        <div class="client-logo bg-warning">
                            G
                        </div>

                        <div class="ms-3">

                            <h5 class="mb-0">
                                Gamma Foods
                            </h5>

                            <small class="text-muted">
                                11.222.333/0001-44
                            </small>

                        </div>

                    </div>

                    <p class="text-muted">

                        Infraestrutura de banco de dados,
                        monitoramento e backup.

                    </p>

                    <span class="badge bg-warning text-dark">
                        Manutenção
                    </span>

                    <hr>

                    <div class="d-flex justify-content-between">

                        <button class="btn btn-outline-primary">
                            Visualizar
                        </button>

                        <button class="btn btn-primary">
                            Editar
                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

</div>

</div>

</body>

</html>
